parameters:
    level: 8
    # PHPDoc types are HINTS, not GUARANTEES. Lazy DAL hydration, framework
    # version drift, and subscriber ordering can violate them at runtime.
    # Treat them as uncertain so defensive `?->`/`?? default`/`is_*()` guards
    # are NOT flagged as redundant. Defense stays.
    treatPhpDocTypesAsCertain: false
    paths:
        - src/
    excludePaths:
        - src/Migration/*
    ignoreErrors:
        # Matches the vendor InvoiceRenderer pattern: chunked per-language search and
        # per-order createVersion are intentional and not N:1 (one search per language,
        # createVersion must run per order to mint a unique version UUID).
        -
            identifier: shopware.noEntityRepositoryInLoop
            path: src/Renderer/QuoteRenderer.php
